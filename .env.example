# ─── LLM Provider (OpenRouter) ────────────────────────────────────────
# Required. One key gives the agents access to all 5 model families
# (DeepSeek, Gemini, Qwen, Mistral) used by the MoA pipeline.
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# ─── MCP servers ───────────────────────────────────────────────────────
# Optional: override the User-Agent the Reddit MCP server sends.
# Leave empty to use a default Mozilla-style UA (Reddit blocks generic UAs).
# Reddit's recommended structured format if you want to set it explicitly:
#   web:<your-app-id>:v0.1 (by /u/<reddit-username>)
REDDIT_USER_AGENT=

# ─── balldontlie API ───────────────────────────────────────────────────
# Optional. The free tier works without a key, but a key gives you higher
# request quotas — useful for the `stats` and `scores` agents.
BALLDONTLIE_API_KEY=

# ─── App config ────────────────────────────────────────────────────────
APP_ENV=development
LOG_LEVEL=INFO
ALLOWED_ORIGINS=http://localhost:5173

# ─── Evaluation persistence ────────────────────────────────────────────
# Optional override. Defaults to <project_root>/data/eval.db when unset.
# Used by /api/runs, /api/runs/{id} and /api/metrics/summary.
EVAL_DB_PATH=
