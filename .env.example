# ─── balldontlie API (nba_stats MCP) ───────────────────────────────────
# Optional. The free tier works without a key, but a key gives you higher
# request quotas — useful for the `stats` and `scores` agents.
BALLDONTLIE_API_KEY=

# ─── App config ────────────────────────────────────────────────────────
APP_ENV=development
LOG_LEVEL=INFO
ALLOWED_ORIGINS=http://localhost:5173
# Optional: require X-App-Access-Token or Authorization: Bearer for API runs (public demo).
APP_ACCESS_TOKEN=

# ─── Database (Postgres + pgvector) ────────────────────────────────────
# Local: postgresql+asyncpg://postgres:postgres@localhost:5432/nba
# Supabase: prefer Session pooler URI from dashboard (Connect → Session mode).
# Use quotes if the password has # / ! / % characters:
# DATABASE_URL="postgresql+asyncpg://postgres.[ref]:PASSWORD@aws-0-....pooler.supabase.com:5432/postgres"
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/nba
DB_ECHO=false
AUTO_MIGRATE=true
MEMORY_EMBEDDING_DIM=1536

# ─── Brief memory (NBA Copilot RAG) ───────────────────────────────────
MEMORY_ENABLED=true
MEMORY_EMBEDDING_MODEL=openai/text-embedding-3-small
MEMORY_DEFAULT_DAYS=14
MEMORY_SEARCH_TOP_K=6
