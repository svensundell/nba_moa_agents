# ─── LLM Provider (OpenRouter) ────────────────────────────────────────
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# ─── MCP servers ───────────────────────────────────────────────────────
# Optional: Brave Search MCP (https://brave.com/search/api/)
# Falls back to a no-op web search if absent.
BRAVE_API_KEY=

# Optional: override the User-Agent the Reddit MCP server sends.
# Leave empty to use a default Mozilla-style UA (Reddit blocks generic UAs).
# Reddit's recommended format if you want to set it explicitly:
#   web:<your-app-id>:v0.1 (by /u/<reddit-username>)
REDDIT_USER_AGENT=

# ─── App config ────────────────────────────────────────────────────────
APP_ENV=development
LOG_LEVEL=INFO
ALLOWED_ORIGINS=http://localhost:5173

# ─── balldontlie API ───────────────────────────────────────────────────
# Required by the NBA MCP server.
BALLDONTLIE_API_KEY=
